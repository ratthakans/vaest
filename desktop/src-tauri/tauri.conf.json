{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VÆST",
  "version": "3.0.0",
  "identifier": "agency.orions.vaest",
  "build": {
    "frontendDist": "../shell"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VÆST",
        "width": 1240,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "shortDescription": "The idea-crystallizing instrument by ORIONS.Agency",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
